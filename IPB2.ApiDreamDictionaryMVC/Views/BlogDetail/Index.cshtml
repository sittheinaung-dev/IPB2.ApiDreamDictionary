@model List<IPB2.ApiDreamDictionaryMVC.Controllers.BlogDetail.BlogDetailResponse>

@{
    ViewData["Title"] = "Blog Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-4 text-success">Blog Details</h1>
        <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
            <i class="bi bi-plus-lg"></i> Create New Detail
        </a>
    </div>

    <!-- Search Bar -->
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <input type="text" name="searchKeyword" class="form-control form-control-lg" placeholder="Search in content or title..." value="@ViewBag.SearchKeyword" />
                <button type="submit" class="btn btn-success btn-lg px-4">Search</button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchKeyword as string))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Clear</a>
                }
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="px-4 py-3">ID</th>
                            <th class="px-4 py-3">Blog Header</th>
                            <th class="px-4 py-3">Content</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 py-3 align-middle">@item.BlogDetailId</td>
                                <td class="px-4 py-3 align-middle">
                                    <span class="badge bg-info text-dark">@item.BlogTitle</span>
                                </td>
                                <td class="px-4 py-3 align-middle">
                                    @(item.BlogContent.Length > 80 ? item.BlogContent.Substring(0, 80) + "..." : item.BlogContent)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
