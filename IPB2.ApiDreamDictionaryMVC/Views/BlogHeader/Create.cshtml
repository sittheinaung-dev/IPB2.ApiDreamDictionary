@model IPB2.ApiDreamDictionaryMVC.Controllers.BlogHeader.BlogHeaderRequest

@{
    ViewData["Title"] = "Create Blog Header";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-primary text-white py-3">
                    <h3 class="mb-0">Create Blog Header</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="mb-3">
                            <label asp-for="BlogId" class="form-label fw-bold">Blog ID</label>
                            <input asp-for="BlogId" class="form-control form-control-lg" placeholder="Enter Numeric ID" />
                            <span asp-validation-for="BlogId" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="BlogTitle" class="form-label fw-bold">Title</label>
                            <input asp-for="BlogTitle" class="form-control form-control-lg" placeholder="Enter Blog Title" />
                            <span asp-validation-for="BlogTitle" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Create</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
