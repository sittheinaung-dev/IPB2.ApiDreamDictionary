@model List<IPB2.ApiDreamDictionaryMVC.Controllers.BlogHeader.BlogHeaderResponse>

@{
    ViewData["Title"] = "Blog Headers";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-4 text-primary">Blog Headers</h1>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-lg"></i> Create New
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="px-4 py-3">ID</th>
                            <th class="px-4 py-3">Title</th>
                            <th class="px-4 py-3 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 py-3 align-middle">@item.BlogId</td>
                                <td class="px-4 py-3 align-middle fw-bold">
                                    <a asp-action="Details" asp-route-id="@item.BlogId" class="text-decoration-none">@item.BlogTitle</a>
                                </td>
                                <td class="px-4 py-3 text-end">
                                    <a asp-action="Details" asp-route-id="@item.BlogId" class="btn btn-sm btn-outline-primary">View Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.05);
        transition: background-color 0.2s ease;
    }
    .card {
        border-radius: 12px;
        overflow: hidden;
    }
    .btn {
        border-radius: 8px;
    }
</style>
