@model List<IPB2.ApiDreamDictionaryMVC.Controllers.BlogDetail.BlogDetailResponse>

@{
    ViewData["Title"] = "Dream Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-4 text-primary mb-0">@ViewBag.HeaderTitle</h1>
            <p class="text-muted lead mt-2 mb-0">Header ID: @ViewBag.HeaderId</p>
        </div>
        <div>
            <a asp-controller="BlogDetail" asp-action="Create" class="btn btn-success btn-lg shadow-sm me-2">
                <i class="bi bi-plus-lg"></i> Add Detail
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                Back to List
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var detail in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm hover-card">
                        <div class="card-body p-4">
                            <h5 class="card-title text-success mb-3">Detail #@detail.BlogDetailId</h5>
                            <p class="card-text">@detail.BlogContent</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body p-5 text-center">
                <i class="bi bi-journal-x display-1 text-muted mb-3"></i>
                <h3>No Details Found</h3>
                <p class="text-muted">There are no detail records associated with this dream header yet.</p>
                <a asp-controller="BlogDetail" asp-action="Create" class="btn btn-primary mt-3">Create the first detail</a>
            </div>
        </div>
    }
</div>

<style>
    .hover-card {
        border-radius: 15px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .card {
        border-radius: 15px;
    }
</style>
