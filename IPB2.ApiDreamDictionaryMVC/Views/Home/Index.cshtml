@{
    ViewData["Title"] = "Home Page";
}

<div class="container py-5 text-center">
    <h1 class="display-3 fw-bold text-primary mb-4">Welcome to Dream Dictionary</h1>
    <p class="lead mb-5 text-muted">A modern platform to manage and explore your dreams directly from the source.</p>
    
    <div class="row g-4 justify-content-center">
        <div class="col-md-5">
            <div class="card h-100 border-0 shadow-sm hover-effect py-4">
                <div class="card-body">
                    <i class="bi bi-journal-text display-4 text-primary mb-3"></i>
                    <h3 class="card-title h4">Blog Headers</h3>
                    <p class="card-text text-muted mb-4">Manage the main categories and titles of your dream logs.</p>
                    <a asp-controller="BlogHeader" asp-action="Index" class="btn btn-outline-primary stretched-link">Explore Headers</a>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card h-100 border-0 shadow-sm hover-effect py-4">
                <div class="card-body">
                    <i class="bi bi-file-earmark-text display-4 text-success mb-3"></i>
                    <h3 class="card-title h4">Blog Details</h3>
                    <p class="card-text text-muted mb-4">Dive deep into the content of each dream record.</p>
                    <a asp-controller="BlogDetail" asp-action="Index" class="btn btn-outline-success stretched-link">Explore Details</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-effect:hover {
        transform: translateY(-5px);
        transition: transform 0.3s ease;
        box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
    }
</style>
